<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sales Order: display current rate -->

    <!-- Payment Receipt: display current rate -->
    <record id="account_payment_form_currency_rate_display" model="ir.ui.view">
        <field name="name">account.payment.form.currency.rate.display</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group1']/div[@name='amount_div']" position="after">
                <group name="exchange_rate_group"
                       groups="base.group_multi_currency"
                       class="mt-2"
                       modifiers="{'invisible': [('currency_id', '=', company_currency_id)]}">
                    <label for="payment_currency_rate" string="Exchange Rate (1 Company = X Payment)"/>
                    <field name="payment_currency_rate"
                           digits="[12,6]"
                           modifiers="{'readonly': [('state', '!=', 'draft')]}"/>
                    <label for="payment_amount_company_currency" string="Amount in Company Currency"/>
                    <field name="payment_amount_company_currency" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
