<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sales Order: display current rate -->

    <!-- Payment Receipt: display current rate -->
    <record id="account_payment_form_currency_rate_display" model="ir.ui.view">
        <field name="name">account.payment.form.currency.rate.display</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group1']/div[@name='amount_div']" position="after">
                <group name="exchange_rate_group"
                       groups="base.group_multi_currency"
                       class="mt-2">
                    <div class="o_row align-items-center gap-2 text-muted"
                         modifiers="{'invisible': [('currency_id', '=', company_currency_id)]}">
                        <label for="payment_currency_rate" class="o_form_label mb-0">Exchange Rate</label>
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <span>1</span>
                            <field name="company_currency_id" readonly="1" options="{'no_open': True}" class="w-auto"/>
                            <span>=</span>
                            <field name="payment_currency_rate"
                                   digits="[12,6]"
                                   class="oe_inline"
                                   modifiers="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="currency_id" readonly="1" options="{'no_open': True}" class="w-auto"/>
                        </div>
                    </div>
                    <div name="amount_company_currency_div"
                         class="o_row align-items-center gap-2 text-muted"
                         modifiers="{'invisible': [('currency_id', '=', company_currency_id)]}">
                        <label for="payment_amount_company_currency" class="o_form_label mb-0">Amount in Company Currency</label>
                        <field name="payment_amount_company_currency" readonly="1" class="oe_inline"/>
                    </div>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
