<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sales Order: display current rate -->

    <!-- Payment Receipt: display current rate -->
    <record id="account_payment_form_currency_rate_display" model="ir.ui.view">
        <field name="name">account.payment.form.currency.rate.display</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group1']//field[@name='ref']" position="after">
                <div name="exchange_rate_group"
                     groups="base.group_multi_currency"
                     class="mt-2 text-muted"
                     modifiers="{'invisible': [('currency_id', '=', company_currency_id)]}">
                    <div class="o_row align-items-center gap-2 flex-wrap">
                        <span class="o_form_label mb-0">Exchange Rate</span>
                        <span>1</span>
                        <field name="company_currency_id" readonly="1" nolabel="1" options="{'no_open': True}" class="oe_inline"/>
                        <span>=</span>
                        <field name="payment_currency_rate"
                               nolabel="1"
                               digits="[12,6]"
                               class="oe_inline"
                               modifiers="{'readonly': [('state', '!=', 'draft')]}"/>
                        <field name="currency_id" readonly="1" nolabel="1" options="{'no_open': True}" class="oe_inline"/>
                    </div>
                    <div class="o_row align-items-center gap-2 mt-1 flex-wrap">
                        <span class="o_form_label mb-0">Amount in Company Currency</span>
                        <field name="payment_amount_company_currency" readonly="1" nolabel="1" class="oe_inline"/>
                        <field name="company_currency_id" readonly="1" nolabel="1" options="{'no_open': True}" class="oe_inline"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
