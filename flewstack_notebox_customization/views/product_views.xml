<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_brand" model="ir.ui.view">
        <field name="name">product.template.form.brand</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_standard_price']/field[@name='categ_id']" position="after">
                <field name="brand_id" options="{'no_quick_create': False}"/>
            </xpath>
        </field>
    </record>

    <record id="product_template_search_view_brand" model="ir.ui.view">
        <field name="name">product.template.search.brand</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//search/field[@name='categ_id']" position="after">
                <field name="brand_id"/>
            </xpath>
            <xpath expr="//search/group" position="inside">
                <filter string="Brand" name="group_by_brand" context="{'group_by': 'brand_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="product_view_search_catalog_brand" model="ir.ui.view">
        <field name="name">product.view.search.catalog.brand</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_view_search_catalog"/>
        <field name="arch" type="xml">
            <xpath expr="//search/field[@name='product_tmpl_id']" position="after">
                <field name="brand_id"/>
            </xpath>
            <xpath expr="//search/searchpanel" position="inside">
                <field name="brand_id"
                       string="Brands"
                       icon="fa-bookmark"
                       enable_counters="1"
                       select="multi"/>
            </xpath>
        </field>
    </record>
</odoo>
