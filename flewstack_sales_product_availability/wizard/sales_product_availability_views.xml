<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="flewstack_sales_product_availability_location_line_view_list" model="ir.ui.view">
        <field name="name">flewstack.sales.product.availability.location.line.view.list</field>
        <field name="model">flewstack_sales_product_availability_location_line</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0"
                  decoration-danger="qty_available &lt; 0"
                  decoration-warning="qty_available == 0"
                  decoration-success="qty_available &gt; 0">
                <field name="location_id"/>
                <field name="qty_on_hand"/>
                <field name="qty_reserved"/>
                <field name="qty_available"/>
                <field name="qty_forecasted"/>
            </list>
        </field>
    </record>

    <record id="flewstack_sales_product_availability_warehouse_line_view_list" model="ir.ui.view">
        <field name="name">flewstack.sales.product.availability.warehouse.line.view.list</field>
        <field name="model">flewstack_sales_product_availability_warehouse_line</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0"
                  decoration-danger="qty_available &lt; 0"
                  decoration-warning="qty_available == 0"
                  decoration-success="qty_available &gt; 0">
                <field name="warehouse_id"/>
                <field name="qty_on_hand"/>
                <field name="qty_reserved"/>
                <field name="qty_available"/>
                <field name="qty_forecasted"/>
            </list>
        </field>
    </record>

    <record id="flewstack_sales_product_availability_history_line_view_list" model="ir.ui.view">
        <field name="name">flewstack.sales.product.availability.history.line.view.list</field>
        <field name="model">flewstack_sales_product_availability_history_line</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="order_id" string="Order"/>
                <field name="order_date"/>
                <field name="qty"/>
                <field name="uom_id"/>
                <field name="price_subtotal"/>
            </list>
        </field>
    </record>

    <record id="flewstack_sales_product_availability_view_form" model="ir.ui.view">
        <field name="name">flewstack.sales.product.availability.view.form</field>
        <field name="model">flewstack_sales_product_availability</field>
        <field name="arch" type="xml">
            <form string="Product Availability" create="false" edit="false" class="o_flewstack_availability_form">
                <sheet>
                    <div class="o_flewstack_availability_header">
                        <div class="o_flewstack_availability_title">
                            <span class="o_flewstack_availability_icon">
                                <i class="fa fa-circle-info"/>
                            </span>
                            <div>
                                <label for="product_id"/>
                                <h3>
                                    <field name="product_id" class="oe_inline" readonly="1"/>
                                </h3>
                                <div class="text-muted">
                                    <field name="product_uom_id" class="oe_inline" readonly="1"/>
                                    <span class="mx-2">|</span>
                                    <field name="company_id" class="oe_inline" readonly="1"/>
                                </div>
                            </div>
                        </div>
                        <div class="o_flewstack_availability_meta">
                            <field name="sale_line_id" readonly="1"/>
                        </div>
                    </div>

                    <div class="o_flewstack_availability_sections">
                        <div class="o_flewstack_availability_card">
                            <div class="o_flewstack_availability_card_header">Locations</div>
                            <field name="location_line_ids"
                                   nolabel="1"
                                   mode="list"
                                   context="{'list_view_ref': 'flewstack_sales_product_availability.flewstack_sales_product_availability_location_line_view_list'}"
                                   options="{'no_create': True, 'no_create_edit': True, 'no_edit': True}"/>
                        </div>
                        <div class="o_flewstack_availability_card">
                            <div class="o_flewstack_availability_card_header">Warehouses</div>
                            <field name="warehouse_line_ids"
                                   nolabel="1"
                                   mode="list"
                                   context="{'list_view_ref': 'flewstack_sales_product_availability.flewstack_sales_product_availability_warehouse_line_view_list'}"
                                   options="{'no_create': True, 'no_create_edit': True, 'no_edit': True}"/>
                        </div>
                        <div class="o_flewstack_availability_card"
                             invisible="not customer_product_history_ids">
                            <div class="o_flewstack_availability_card_header">Customer Product History</div>
                            <field name="customer_product_history_ids"
                                   nolabel="1"
                                   mode="list"
                                   context="{'list_view_ref': 'flewstack_sales_product_availability.flewstack_sales_product_availability_history_line_view_list'}"
                                   options="{'no_create': True, 'no_create_edit': True, 'no_edit': True}"/>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
