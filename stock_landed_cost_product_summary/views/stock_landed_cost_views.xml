<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_stock_landed_cost_form_product_summary" model="ir.ui.view">
        <field name="name">stock.landed.cost.form.product.summary</field>
        <field name="model">stock.landed.cost</field>
        <field name="inherit_id" ref="stock_landed_costs.view_stock_landed_cost_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/div[@class='oe_title']" position="before">
                <div class="oe_button_box" name="button_box">
                    <button type="object"
                            name="action_view_landed_cost_product_summary"
                            class="oe_stat_button"
                            icon="fa-cubes">
                        <field name="landed_cost_product_count" widget="statinfo" string="Products"/>
                    </button>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
