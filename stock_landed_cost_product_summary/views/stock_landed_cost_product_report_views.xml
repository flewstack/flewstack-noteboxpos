<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_stock_landed_cost_product_report_list" model="ir.ui.view">
        <field name="name">stock.landed.cost.product.report.list</field>
        <field name="model">stock.landed.cost.product.report</field>
        <field name="arch" type="xml">
            <list string="Landed Cost Products" export_xlsx="1" create="0" delete="0">
                <field name="product_id"/>
                <field name="quantity" optional="hide"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="original_unit_cost" widget="monetary"/>
                <field name="new_unit_cost" widget="monetary"/>
                <field name="original_value_total" widget="monetary"/>
                <field name="new_value_total" widget="monetary"/>
            </list>
        </field>
    </record>

    <record id="view_stock_landed_cost_product_report_search" model="ir.ui.view">
        <field name="name">stock.landed.cost.product.report.search</field>
        <field name="model">stock.landed.cost.product.report</field>
        <field name="arch" type="xml">
            <search string="Landed Cost Products">
                <field name="product_id"/>
                <field name="cost_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </search>
        </field>
    </record>

    <record id="action_stock_landed_cost_product_report" model="ir.actions.act_window">
        <field name="name">Landed Cost Products</field>
        <field name="res_model">stock.landed.cost.product.report</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_stock_landed_cost_product_report_list"/>
        <field name="search_view_id" ref="view_stock_landed_cost_product_report_search"/>
        <field name="context">{}</field>
    </record>
</odoo>
