<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_form_inherit_flewstack_transfer_cash" model="ir.ui.view">
        <field name="name">account.move.form.flewstack.transfer.cash</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <button name="action_open_transfer_cash" type="object" string="Transfer Cash" class="btn-primary"
                        modifiers="{'invisible': ['|','|',('state','!=','posted'),('move_type','!=','entry'),('journal_id.type','!=','cash')]}"/>
            </xpath>
        </field>
    </record>
</odoo>
