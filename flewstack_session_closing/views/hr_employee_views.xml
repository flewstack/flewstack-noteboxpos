<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_flewstack_session_closing" model="ir.ui.view">
        <field name="name">hr.employee.form.flewstack.session.closing</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']/group[@name='settings_group']" position="inside">
                <group string="POS Cash Hand Over" name="pos_cash_handover" groups="hr.group_hr_user">
                    <field name="cash_clear_id"/>
                    <field name="cash_clear_password" password="True"/>
                    <field name="cash_journal_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
