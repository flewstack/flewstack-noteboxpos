<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_product_template_pos_cost_alert" model="ir.ui.view">
        <field name="name">product.template.form.flewstack.pos.cost.alert</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="point_of_sale.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='pos']/group/group[@name='pos']" position="after">
                <group string="Cost Protection">
                    <field name="flewstack_average_cost"
                           widget="monetary"
                           options="{'currency_field': 'currency_id'}"
                           readonly="1"/>
                    <field name="flewstack_threshold"
                           widget="monetary"
                           options="{'currency_field': 'currency_id'}"/>
                    <field name="origin_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
